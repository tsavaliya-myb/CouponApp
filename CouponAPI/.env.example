# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/coupondb

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-refresh-secret-in-production-use-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── MSG91 (OTP SMS) ──────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_TEMPLATE_ID=your_msg91_template_id_here
MSG91_SENDER_ID=CPNAPP

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ─── OneSignal ────────────────────────────────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here
