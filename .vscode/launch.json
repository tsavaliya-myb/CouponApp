{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Server (ts-node)",
            "skipFiles": [
                "<node_internals>/**",
                "${workspaceFolder}/CouponAPI/node_modules/**/*.js"
            ],
            "program": "${workspaceFolder}/CouponAPI/src/server.ts",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "cwd": "${workspaceFolder}/CouponAPI",
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug via npm run dev",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/CouponAPI",
            "restart": true,
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}